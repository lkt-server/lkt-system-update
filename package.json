{
  "name": "lkt-system-update",
  "version": "1.0.3",
  "description": "One command line, everything up to date (apt, dnf, yum, pacman, yaourt, zypper, flatpak, npm and snap)",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "files": [
    "dist/*",
    "bin/*"
  ],
  "bin": {
    "lkt-system-update": "./bin/bin.js"
  },
  "type": "module",
  "preferGlobal": true,
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "keywords": [
    "terminal",
    "command line interface",
    "cli",
    "system update",
    "command",
    "lkt",
    "linux"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts"
  },
  "author": "Antonio Ibáñez",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "@types/node": "^22.14.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "colors": "^1.4.0",
    "commander": "^13.1.0",
    "figlet": "^1.8.1",
    "lkt-server-kernel": "^1.0.0",
    "vite-node": "^1.6.1"
  }
}
